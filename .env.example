# AI Document Indexer - Example Environment Configuration
# Копируйте этот файл в .env и заполните реальными значениями
# DO NOT commit .env file with real credentials to version control!
# НЕ коммитьте файл .env с реальными учетными данными в систему версионирования!

# ============================================================================
# GOOGLE GEMINI API CONFIGURATION
# ============================================================================
# Получить API-ключ: https://aistudio.google.com/
# Get API key: https://aistudio.google.com/
# 
# Инструкция:
# 1. Откройте https://aistudio.google.com/
# 2. Нажмите "Get API key" или "API keys" в левом меню
# 3. Создайте новый API-ключ нажатием "Create API key"
# 4. Скопируйте выданный ключ (начинается с "AIzaSy...")
# 5. Замените PLACEHOLDER на реальный ключ ниже

GEMINI_API_KEY=PLACEHOLDER_AIzaSy_YOUR_ACTUAL_API_KEY_HERE_1234567890

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Режим выполнения: development, staging, production
APP_ENV=development

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Максимальный размер файла для обработки (в МБ)
MAX_FILE_SIZE_MB=100

# Максимальное количество одновременно обрабатываемых файлов
MAX_CONCURRENT_PROCESSING=5

# Таймаут для запроса к Gemini API (в секундах)
GEMINI_API_TIMEOUT=60

# ============================================================================
# DATABASE SETTINGS (if applicable)
# ============================================================================

# Database type: sqlite, postgresql, mysql
DB_TYPE=sqlite

# SQLite database file path (relative or absolute)
DB_PATH=./data/indexer.db

# Для PostgreSQL (если используется):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ai_document_indexer
# DB_USER=indexer_user
# DB_PASSWORD=secure_password_here

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Секретный ключ для подписи сессий (используется для F5-восстановления)
# Можно сгенерировать любую случайную строку из букв и цифр длиной >= 32
SESSION_SECRET_KEY=PLACEHOLDER_USE_ANY_RANDOM_32_CHARACTER_STRING_HERE_abcd1234

# Время жизни сессии (в минутах)
SESSION_TIMEOUT_MINUTES=1440

# Включить CORS (для фронтенда, если используется отдельный сервер)
ENABLE_CORS=false

# Разрешенные источники для CORS (через запятую)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# LANGUAGE AND OUTPUT SETTINGS
# ============================================================================

# Языковой профиль по умолчанию: ru-old, ru-soviet, ru-modern, en-old, en-modern
DEFAULT_DOCUMENT_LANGUAGE=ru-modern

# Язык вывода: ru, en
OUTPUT_LANGUAGE=ru

# ============================================================================
# ARCHIVAL DOCUMENT SETTINGS
# ============================================================================

# Поддерживаемые форматы файлов (через запятую)
SUPPORTED_FILE_FORMATS=.jpg,.jpeg,.png,.tiff,.pdf

# Минимальный размер файла для обработки (в КБ)
MIN_FILE_SIZE_KB=10

# ============================================================================
# LOGGING AND MONITORING
# ============================================================================

# Директория для логов
LOG_DIR=./logs

# Включить логирование в файл
LOG_TO_FILE=true

# Включить логирование в консоль
LOG_TO_CONSOLE=true

# Максимальный размер файла лога перед ротацией (в МБ)
LOG_MAX_SIZE_MB=10

# Количество хранимых файлов логов
LOG_BACKUP_COUNT=5

# ============================================================================
# PERFORMANCE AND OPTIMIZATION
# ============================================================================

# Включить кэширование результатов обработки
ENABLE_CACHING=true

# TTL (Time To Live) для кэша (в часах)
CACHE_TTL_HOURS=24

# Размер пула рабочих потоков для обработки файлов
WORKER_THREAD_POOL_SIZE=4

# ============================================================================
# DEBUG AND DEVELOPMENT SETTINGS
# ============================================================================

# Включить режим отладки (выводить дополнительную информацию)
DEBUG_MODE=false

# Сохранять временные файлы при обработке (для отладки)
KEEP_TEMP_FILES=false

# Директория для временных файлов
TEMP_DIR=./temp
